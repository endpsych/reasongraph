# ReasonGraph local development environment variables.
#

# ---------------------------------------------------------------------
# SQLite
# ---------------------------------------------------------------------

REASONGRAPH_SQLITE_PATH=data/app/reasongraph.db

# ---------------------------------------------------------------------
# Neo4j backend connection
# ---------------------------------------------------------------------

REASONGRAPH_NEO4J_URI=bolt://localhost:7687
REASONGRAPH_NEO4J_USERNAME=neo4j
REASONGRAPH_NEO4J_PASSWORD=change_me
REASONGRAPH_NEO4J_DATABASE=neo4j

# ---------------------------------------------------------------------
# Neo4j Docker settings
# ---------------------------------------------------------------------

NEO4J_VERSION=5.26
NEO4J_PASSWORD=change_me
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_HEAP_INITIAL=512m
NEO4J_HEAP_MAX=1G
NEO4J_PAGECACHE=512m

# ---------------------------------------------------------------------
# OpenAI
# ---------------------------------------------------------------------
# Do not put real keys in .env.example.

OPENAI_API_KEY=